# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated access tokens. Clients pass one as `Authorization: Bearer <token>`
# or (since MCP_ALLOW_URL_TOKENS=true) in the URL path: /imagine/<token>/
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
MCP_TOKENS=replace_with_a_long_random_token

# Optional overrides (sensible defaults are set in docker-compose.yml / code):
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# IMAGE_MAX_CONCURRENCY=2          # concurrent generations
# MCP_PREVIEW_MAX=1536             # inline preview max dimension (px)
# IMAGE_MAX_AGE_DAYS=30           # auto-delete generated images older than this (0 = keep forever)
# REQUESTS_MAX_FILES=10000        # cap on retained request-log files
# MAX_DOWNLOAD_BYTES=26214400     # max bytes per input image download (edit_image)
# MAX_IMAGE_PIXELS=64000000       # decompression-bomb guard for input images
# ALLOW_PRIVATE_IMAGE_URLS=false  # set true ONLY for local testing of localhost/private input URLs
# SENTRY_DSN=
